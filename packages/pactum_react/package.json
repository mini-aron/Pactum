{
  "name": "@pactum-labs/react",
  "version": "0.0.1",
  "description": "React UI for Pactum electronic contract documents",
  "license": "MIT",
  "keywords": [
    "contracts",
    "react",
    "canvas",
    "pdf",
    "form-builder",
    "e-signature"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "test": "pnpm typecheck",
    "clean": "rm -rf dist storybook-static",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@pactum-labs/core": "workspace:*",
    "react-pdf": "^9.2.1",
    "react-signature-canvas": "^1.0.6"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-signature-canvas": "^1.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1"
  }
}
